# ---------------------------------------------------------------------------
# Deployment (docker-compose.prod.yml). See DEPLOY.md.
# ---------------------------------------------------------------------------
# Public domain (A record → this server). Caddy auto-issues a Let's Encrypt cert.
DOMAIN=fishingteam.su
# CORS allow-list for the browser app (same-origin behind Caddy, but set it too).
FRONTEND_ALLOWED_ORIGINS=https://fishingteam.su
# Real STT (asr-service / faster-whisper). Model is baked at build time.
WHISPER_MODEL=base
WHISPER_LANGUAGE=ru

APP_ENV=prod
# Shared secret for internal/desktop APIs. MUST be changed. openssl rand -hex 32
INTERNAL_API_TOKEN=dev-internal-token

POSTGRES_DB=grey_cardinal
POSTGRES_USER=grey
# MUST be changed. openssl rand -hex 24
POSTGRES_PASSWORD=grey
DATABASE_URL=postgresql+asyncpg://grey:grey@postgres:5432/grey_cardinal

BRAIN_API_HOST=0.0.0.0
BRAIN_API_PORT=8000
BRAIN_API_BASE_URL=http://brain-api:8000

TELEGRAM_BOT_HOST=0.0.0.0
TELEGRAM_BOT_PORT=8010
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PUBLIC_BASE_URL=https://example.ngrok-free.app
TELEGRAM_BOT_BASE_URL=http://telegram-bot:8010
# Long-polling instead of webhooks. Required when the host's network blocks
# inbound Telegram delivery to the webhook (the bot pulls updates via tg-proxy).
TELEGRAM_USE_POLLING=true

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

BOARD_PROVIDER=mock
# YouGile board integration for the demo brain pipeline.
# Set YOUGILE_ENABLED=true AND fill API_KEY + COLUMN_TODO_ID to sync confirmed
# tasks into YouGile. When false/unconfigured the local board still works and
# the integration honestly reports status=disabled.
YOUGILE_ENABLED=false
YOUGILE_API_BASE_URL=https://ru.yougile.com
YOUGILE_API_KEY=
YOUGILE_COMPANY_ID=
YOUGILE_PROJECT_ID=
YOUGILE_BOARD_ID=
YOUGILE_COLUMN_BACKLOG_ID=
YOUGILE_COLUMN_TODO_ID=
YOUGILE_COLUMN_IN_PROGRESS_ID=
YOUGILE_COLUMN_REVIEW_ID=
YOUGILE_COLUMN_BLOCKED_ID=
YOUGILE_COLUMN_DONE_ID=
# Optional assignee → YouGile user-id mapping (JSON). If unset, assignee goes
# into the task description only.
YOUGILE_USER_MAP=

# Demo brain store (proposals/tasks/board). Defaults to {UPLOADS_DIR}/brain/brain.json.
BRAIN_STORE_PATH=

REMINDER_DEADLINE_HOURS_BEFORE=2
REMINDER_STALE_HOURS=24
EVENING_DIGEST_HOUR=20
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_WORKSPACE_NAME=Hackathon Team
DEFAULT_TELEGRAM_CHAT_ID=

# Политика извлечения задач (Developer 1 core flow)
TASK_EXTRACTION_MIN_CONFIDENCE=0.65
TASK_EXTRACTION_REQUIRE_ACTION_VERB=true

# Детекция дублей
DUPLICATE_SIMILARITY_THRESHOLD=0.72

# Анти-спам политика напоминаний
REMINDER_MIN_INTERVAL_MINUTES=120
REMINDER_MAX_DAILY_PER_USER=3
REMINDER_QUIET_HOURS_START=22:00
REMINDER_QUIET_HOURS_END=09:00

# Dev/demo: /demo_core auto-confirms proposals into tasks (set false for prod).
DEMO_CORE_AUTO_CONFIRM=true
# Dev/demo: desktop transcript proposals auto-confirm into tasks (set false for prod).
DESKTOP_AUTO_CONFIRM_PROPOSALS=true

# Telemost bot worker (second audio source). mock = no browser (default).
# playwright = real browser joiner (optional, not enabled unless installed).
TELEMOST_WORKER_MODE=mock
TELEMOST_BOT_NAME=Grey Cardinal Bot
TELEMOST_JOIN_TIMEOUT_SEC=60
TELEMOST_MAX_MEETING_MINUTES=120

AUDIO_WORKER_HOST=0.0.0.0
AUDIO_WORKER_PORT=8020
AUDIO_ASR_PROVIDER=mock
AUDIO_MOCK_TEXT=Петя, сделай оплату к четвергу
AUDIO_WORKER_SAVE_CHUNKS=false
AUDIO_WORKER_CHUNKS_DIR=/tmp/grey-cardinal-audio-chunks
AUDIO_FASTER_WHISPER_MODEL=base

FRONTEND_DASHBOARD_PORT=5173

LOG_LEVEL=INFO
