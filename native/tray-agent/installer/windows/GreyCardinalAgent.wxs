<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Grey Cardinal Agent"
    Manufacturer="Grey Cardinal"
    Version="$(ProductVersion)"
    UpgradeCode="{1E71D253-489E-4B19-997F-0D28E904A5E2}"
    Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Grey Cardinal Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Grey Cardinal Agent" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Grey Cardinal Agent" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Grey Cardinal Agent" Level="1">
      <ComponentRef Id="AgentExecutable" />
      <ComponentRef Id="AgentAutostart" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>
  </Package>

  <Fragment>
    <Component Id="AgentExecutable" Directory="INSTALLFOLDER" Guid="{85B7C623-E65A-476A-A718-9BD5527E9C40}">
      <File
        Id="AgentExeFile"
        Source="$(StageDir)\GreyCardinalAgent.exe"
        Name="GreyCardinalAgent.exe"
        KeyPath="yes" />
    </Component>

    <Component Id="AgentAutostart" Directory="INSTALLFOLDER" Guid="{5F9EE2AC-7F16-41D5-8E0E-1FC76DF68378}">
      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="GreyCardinalAgent"
        Type="string"
        Value="&quot;[INSTALLFOLDER]GreyCardinalAgent.exe&quot;"
        KeyPath="yes" />
    </Component>

    <Component Id="ApplicationShortcut" Directory="ApplicationProgramsFolder" Guid="{48513376-090F-43C9-9423-6EE9B50F32A9}">
      <Shortcut
        Id="GreyCardinalAgentShortcut"
        Name="Grey Cardinal Agent"
        Description="Grey Cardinal meeting agent"
        Target="[#AgentExeFile]"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\Grey Cardinal\Agent"
        Name="installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
