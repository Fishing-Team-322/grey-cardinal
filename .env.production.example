# Production template for https://fishingteam.su.
# Real secrets are required. Never commit `.env.production`.
# No mock fallback is allowed in production.
# Ollama is internal-only through docker-compose.prod.yml; do not publish 11434.

DOMAIN=fishingteam.su
FRONTEND_ALLOWED_ORIGINS=https://fishingteam.su,https://api.fishingteam.su

APP_ENV=production
LOG_LEVEL=INFO
INTERNAL_API_TOKEN=replace-with-random-token
JWT_SECRET=replace-with-long-random-secret
JWT_COOKIE_SECURE=true
BOARD_CREDS_ENCRYPTION_KEY=replace-with-fernet-compatible-key

POSTGRES_DB=grey_cardinal
POSTGRES_USER=grey
POSTGRES_PASSWORD=replace-with-random-password
DATABASE_URL=postgresql+asyncpg://grey:replace-with-random-password@postgres:5432/grey_cardinal

BRAIN_API_HOST=0.0.0.0
BRAIN_API_PORT=8000
BRAIN_API_BASE_URL=http://brain-api:8000

TELEGRAM_MODE=polling
TELEGRAM_BOT_TOKEN=replace-with-real-token
TELEGRAM_BOT_USERNAME=replace-with-bot-username
TELEGRAM_WEBHOOK_SECRET=replace-if-webhook-mode
TELEGRAM_PUBLIC_BASE_URL=https://fishingteam.su
TELEGRAM_BOT_BASE_URL=http://telegram-bot:8010
HTTPS_PROXY=http://tg-proxy:8888
NO_PROXY=brain-api,localhost,127.0.0.1

# ── LLM (semantic parser) ────────────────────────────────────────────
# Production strategy: Groq (primary, via VPN) -> OpenRouter (fallback, direct)
#                      -> Ollama (local, last resort).
# The RU server IP is geo-blocked by Groq (HTTP 403), so Groq egress goes
# through the vpn-proxy (sing-box). OpenRouter is reachable from RU directly,
# so it stays the VPN-independent fallback. Keys come ONLY from this file
# (chmod 600) — never commit real values.
LLM_PROVIDER=external_api
LLM_EXTERNAL_BASE_URL=https://api.groq.com/openai/v1
LLM_EXTERNAL_API_KEY=replace-with-groq-api-key
LLM_MODEL=llama-3.3-70b-versatile
LLM_STRICT_JSON=true
LLM_TIMEOUT_SECONDS=8
LLM_MAX_RETRIES=2
# Route primary (Groq) traffic through the VPN proxy container. Leave empty to
# go direct (only works from a non-blocked IP).
LLM_PROXY=http://vpn-proxy:8889

# Fallback: OpenRouter (only on primary failure: timeout/429/5xx/invalid JSON).
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_PROVIDER=external_api
LLM_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
LLM_FALLBACK_API_KEY=replace-with-openrouter-api-key
LLM_FALLBACK_MODEL=deepseek/deepseek-chat-v3:free
LLM_FALLBACK_TIMEOUT_SECONDS=12
# Fallback proxy: EMPTY = direct (OpenRouter works from RU without the VPN).
LLM_FALLBACK_PROXY=

# Local Ollama (dev/privacy only).
LLM_LOCAL_BASE_URL=http://ollama:11434/v1
LLM_LOCAL_MODEL=

# ── VPN egress (vpn-proxy / sing-box) ────────────────────────────────
# Foreign Hysteria2 exits used to reach Groq. Password is the per-user secret
# from the VPN subscription (the UUID after the scheme). Hosts are the NL/CH
# Hysteria2 nodes. sing-box auto-fails over between them (urltest).
VPN_HY2_PASSWORD=replace-with-vpn-hysteria2-password
VPN_NODE_NL_HOST=nl01-ntr-hy01.tcp-reset-club.net
VPN_NODE_CH_HOST=che01-plr-hy01.tcp-reset-club.net
# Extra failover exit (VLESS-Reality). Despite the [RU] label in its
# subscription, this node actually exits in Dubai, so it works for Groq.
VPN_DUBAI_HOST=ru-node.madrigal.ru
VPN_DUBAI_UUID=replace-with-vless-reality-uuid

# YouGile credentials are encrypted per team in the database.
BOARD_PROVIDER=mock
YOUGILE_ENABLED=true
YOUGILE_API_BASE_URL=https://yougile.com/api-v2
YOUGILE_RATE_LIMIT_PER_MINUTE=50
YOUGILE_ONBOARDING_TOKEN_TTL_SECONDS=90
YOUGILE_DISCOVERY_SCHEDULE_HOURS=6
PUBLIC_BASE_URL=https://fishingteam.su

ASR_SERVICE_URL=http://asr-service:8030
AUDIO_ASR_PROVIDER=http
WHISPER_MODEL=base
WHISPER_LANGUAGE=ru

EVENING_DIGEST_HOUR=20
REMINDER_DEADLINE_HOURS_BEFORE=2
REMINDER_STALE_HOURS=24
REMINDER_MIN_INTERVAL_MINUTES=120
REMINDER_MAX_DAILY_PER_USER=3
REMINDER_QUIET_HOURS_START=22:00
REMINDER_QUIET_HOURS_END=09:00

DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_WORKSPACE_NAME=Grey Cardinal
DEFAULT_TELEGRAM_CHAT_ID=
TASK_EXTRACTION_MIN_CONFIDENCE=0.65
DUPLICATE_SIMILARITY_THRESHOLD=0.72
DEMO_CORE_AUTO_CONFIRM=false
DESKTOP_AUTO_CONFIRM_PROPOSALS=false

AUDIO_WORKER_HOST=0.0.0.0
AUDIO_WORKER_PORT=8020
AUDIO_WORKER_SAVE_CHUNKS=false
AUDIO_WORKER_CHUNKS_DIR=/tmp/grey-cardinal-audio-chunks
FRONTEND_DASHBOARD_PORT=5173

# ── Yandex Telemost OAuth (required to enable Telemost room creation) ──────────
# From the Yandex OAuth app (platform: Web). Secret is rotated out-of-band and set
# only here on the server. Redirect URI must match the app config EXACTLY.
YANDEX_TELEMOST_CLIENT_ID=
YANDEX_TELEMOST_CLIENT_SECRET=
YANDEX_TELEMOST_REDIRECT_URI=https://fishingteam.su/api/integrations/yandex-telemost/oauth/callback
YANDEX_TELEMOST_SCOPES=telemost-api:conferences.create telemost-api:conferences.read telemost-api:conferences.update
TELEMOST_RECORDER_PARTICIPANT_NAME=Grey Cardinal — запись
TELEMOST_RECORDER_SEGMENT_SECONDS=15
TELEMOST_RECORDER_MAX_SESSION_MINUTES=180
