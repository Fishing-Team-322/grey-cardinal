fishingteam.su {
	encode zstd gzip

	# /internal/* — это service-to-service endpoints brain-api (X-Internal-Token).
	# Наружу закрыто полностью, чтобы их нельзя было дёрнуть из браузера/интернета.
	handle /internal/* {
		respond 404
	}

	handle /webhooks/telegram {
		reverse_proxy telegram-bot:8010
	}

	handle /api/audio/upload {
		reverse_proxy audio-worker:8020
	}

	@brain path /api/* /ws/* /desktop/* /health /ready /docs /docs/* /openapi.json /redoc /redoc/*
	handle @brain {
		reverse_proxy brain-api:8000
	}

	handle {
		reverse_proxy frontend:5173
	}
}

api.fishingteam.su {
	encode zstd gzip

	# Тот же запрет: api.fishingteam.su проксирует brain-api, но НЕ /internal/*.
	handle /internal/* {
		respond 404
	}

	handle {
		reverse_proxy brain-api:8000
	}
}
