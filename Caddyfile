# Caddy reverse proxy for Grey Cardinal (auto-HTTPS via Let's Encrypt).
# {$DOMAIN} comes from the environment (see docker-compose.prod.yml / .env).

{$DOMAIN} {
	encode zstd gzip

	# Telegram delivers webhook updates here.
	handle /webhooks/telegram {
		reverse_proxy telegram-bot:8010
	}

	# Backend API + live events + desktop ingestion → brain-api.
	# WebSocket upgrades on /ws/* are handled transparently by reverse_proxy.
	@backend path /api/* /ws/* /desktop/* /health /ready /docs /docs/* /openapi.json /redoc /redoc/*
	handle @backend {
		reverse_proxy brain-api:8000
	}

	# Everything else is the static Grey Cardinal app.
	handle {
		reverse_proxy frontend:5173
	}
}

# API subdomain — exposes brain-api directly (Swagger UI at /docs).
api.{$DOMAIN} {
	encode zstd gzip
	reverse_proxy brain-api:8000
}
