fishingteam.su {
	encode zstd gzip

	handle /webhooks/telegram {
		reverse_proxy telegram-bot:8010
	}

	handle /api/audio/upload {
		reverse_proxy audio-worker:8020
	}

	@brain path /api/* /ws/* /desktop/* /health /ready /docs /docs/* /openapi.json /redoc /redoc/* /internal/debug/health/dependencies
	handle @brain {
		reverse_proxy brain-api:8000
	}

	handle {
		reverse_proxy frontend:5173
	}
}

api.fishingteam.su {
	encode zstd gzip
	reverse_proxy brain-api:8000
}
