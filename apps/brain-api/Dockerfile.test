# Test image: installs brain-api + dev deps (Linux wheels), source mounted at runtime.
FROM python:3.12-slim
ENV PYTHONUNBUFFERED=1 PIP_DISABLE_PIP_VERSION_CHECK=1
WORKDIR /app
COPY packages/contracts/python /app/packages/contracts/python
RUN pip install -e /app/packages/contracts/python
COPY apps/brain-api/pyproject.toml /app/apps/brain-api/pyproject.toml
COPY apps/brain-api/alembic.ini /app/apps/brain-api/alembic.ini
COPY apps/brain-api/alembic /app/apps/brain-api/alembic
COPY apps/brain-api/src /app/apps/brain-api/src
COPY apps/brain-api/tests /app/apps/brain-api/tests
COPY apps/brain-api/evals /app/apps/brain-api/evals
COPY apps/frontend /app/apps/frontend
COPY Caddyfile docker-compose.prod.yml /app/
RUN pip install -e "/app/apps/brain-api[dev]"
WORKDIR /app
CMD ["pytest", "-q", "-c", "apps/brain-api/pyproject.toml", "apps/brain-api/tests"]
